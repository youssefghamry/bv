            .grid-2col {
                grid-template-columns: 1fr;
            }
            .styled-table th, .styled-table td {
                font-size: 11px;
                padding: 6px;
            }
        }

        /* خط Cairo وحجم 12 Pixel ملزم في جميع المتن حتى داخل الجداول */
        .footer-note {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 2px dashed #cbdbe0;
            text-align: center;
            font-size: 11px;
            color: #5f6c7a;
        }
        i.icon-spacer {
            margin-left: 6px;
        }
        .obligation-block {
            background: #fef6e8;
            padding: 12px 20px;
            border-radius: 20px;
        }
    </style>
</head>
